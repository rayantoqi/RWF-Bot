# ═══════════════════════════════════════════════════════════════════════════════
# 📁 .env.example — متغيرات البيئة المطلوبة
# انسخ هذا الملف إلى .env واملأ القيم
# ═══════════════════════════════════════════════════════════════════════════════

# 🤖 Discord Bot (إلزامي)
TOKEN=YOUR_BOT_TOKEN_HERE
CLIENT_ID=YOUR_APPLICATION_ID_HERE
CLIENT_SECRET=YOUR_OAUTH2_SECRET_HERE
OWNER_ID=YOUR_DISCORD_USER_ID_HERE

# 🌐 إعدادات الموقع
# Railway يُنشئ PORT تلقائياً — لا تضفه هنا إلا للتطوير المحلي
# PORT=8080

# SESSION_SECRET: نص عشوائي طويل لتشفير الجلسات (إلزامي للإنتاج)
SESSION_SECRET=change_this_to_a_random_long_string_minimum_32_chars

# CALLBACK_URL: اختياري — يُكتشف تلقائياً على Railway
# للتطوير المحلي:
# CALLBACK_URL=http://localhost:8080/auth/discord/callback
# للإنتاج على Railway (أو اتركه فارغاً ليُكتشف تلقائياً):
# CALLBACK_URL=https://your-project.up.railway.app/auth/discord/callback

# 🎨 اختياري — بادئة الأوامر القديمة
# PREFIX=!

